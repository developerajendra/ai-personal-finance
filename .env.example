# AI Configuration
# Main AI Provider: 'gemini' or 'ollama'
AI_PROVIDER=gemini

# Use-case specific overrides (optional)
# AI_CHAT_PROVIDER=gemini
# AI_JSON_PROVIDER=gemini
# AI_ANALYSIS_PROVIDER=gemini

# Gemini Configuration
AI_CHAT_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Ollama Configuration (if using Ollama)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3:latest

# Gmail OAuth Configuration
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Gmail Tokens (optional - can be set manually or obtained via OAuth flow)
# These are typically obtained automatically via OAuth callback and stored in cookies
# Set these only if you want to use static tokens from environment variables
# GMAIL_ACCESS_TOKEN=your_access_token_here
# GMAIL_REFRESH_TOKEN=your_refresh_token_here

# Portfolio Agent Configuration
PORTFOLIO_AGENT_ENABLED=true
PORTFOLIO_AGENT_INTERVAL=300000

# Zerodha Kite API Configuration
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here
ZERODHA_REDIRECT_URI=http://localhost:3000/api/zerodha/callback

# Node Environment
NODE_ENV=development
