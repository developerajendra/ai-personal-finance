# ──────────────────────────────────────────────────
# Server-Level Configuration (required)
# ──────────────────────────────────────────────────

# NextAuth / Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_SECRET=same-as-NEXTAUTH_SECRET

# Encryption key for per-user secrets in DB (must be exactly 32 chars)
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-key!!

# Google OAuth — same Client ID/Secret can power both flows. In Google Cloud Console
# (APIs & Services → Credentials → your OAuth 2.0 Client → Authorized redirect URIs)
# you MUST add every URI you use, exactly (scheme, host, port, path — no trailing slash on path):
#   http://localhost:3000/api/auth/callback/google  ← required for "Sign in with Google" (NextAuth)
#   http://localhost:3000/api/gmail/callback        ← optional; Gmail API connect in Settings
GMAIL_CLIENT_ID=your_google_client_id_here
GMAIL_CLIENT_SECRET=your_google_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ──────────────────────────────────────────────────
# Optional / Per-User (moved to Settings page)
# ──────────────────────────────────────────────────

# AI Configuration (fallback; users can override in Settings)
AI_PROVIDER=gemini
AI_CHAT_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Ollama Configuration (if using Ollama locally)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3:latest

# Zerodha Kite API (fallback; users add their own in Settings)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URI=http://localhost:3000/api/zerodha/callback

# Portfolio Agent
PORTFOLIO_AGENT_ENABLED=true
PORTFOLIO_AGENT_INTERVAL=300000

# Node Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
